    <!-- ===== JAVASCRIPT - ÁREA DE PROGRAMAÇÃO ===== -->
    <script>
        // ===== INÍCIO DO JAVASCRIPT =====
        // JavaScript controla a interatividade do site (cliques, animações, formulários, etc.)

        // Variável que guarda o botão "Voltar ao topo"
        // document.getElementById() encontra um elemento pelo seu id
        var botaoTopo = document.getElementById("btn-topo");

        // Variável que guarda o formulário
        var formulario = document.getElementById("formulario");

        // Variável que guarda a mensagem de sucesso
        var mensagemSucesso = document.getElementById("mensagem-sucesso");

        // ===== FUNÇÃO: MOSTRAR/ESCONDER O BOTÃO DE TOPO =====
        // Essa função verifica se a página foi rolada para baixo
        window.onscroll = function() {
            // window.onscroll = função que roda toda vez que a página é rolada
            if (window.scrollY > 300) {
                // Se a rolagem for maior que 300 pixels (rolou para baixo)
                botaoTopo.style.display = "block";
                // Mostra o botão (display = block faz ele aparecer)
            } else {
                // Senão (se a página está no topo ou perto dele)
                botaoTopo.style.display = "none";
                // Esconde o botão (display = none faz ele sumir)
            }
            // Fim do if/else
        };
        // Fim da função onscroll

        // ===== FUNÇÃO: CLICAR NO BOTÃO DE TOPO =====
        botaoTopo.onclick = function() {
            // Quando o botão de topo é clicado
            window.scrollTo({
                // window.scrollTo() = rolar a página para uma posição
                top: 0,
                // top: 0 = vai para o topo da página
                behavior: "smooth"
                // behavior: "smooth" = rolagem suave (animação)
            });
            // Fim do scrollTo
        };
        // Fim da função onclick do botão

        // ===== FUNÇÃO: ENVIAR O FORMULÁRIO =====
        formulario.onsubmit = function(evento) {
            // Quando o formulário é enviado
            evento.preventDefault();
            // preventDefault() impede que a página recarregue ao enviar

            // Pega o valor que o usuário digitou no campo nome
            var nomeUsuario = document.getElementById("nome").value;

            // Mostra uma mensagem de agradecimento personalizada
            // alert() = janela pop-up do navegador
            alert("Obrigado, " + nomeUsuario + "! Sua mensagem foi recebida. 😊");

            // Mostra a mensagem de sucesso no site (troca display: none para block)
            mensagemSucesso.style.display = "block";

            // Limpa os campos do formulário
            formulario.reset();
            // reset() = limpa todos os campos do formulário

            // Esconde a mensagem de sucesso após 5 segundos
            setTimeout(function() {
                // setTimeout() = executa algo após um tempo determinado
                // 5000 = 5000 milissegundos = 5 segundos
                mensagemSucesso.style.display = "none";
                // Esconde a mensagem novamente
            }, 5000);
            // Fim do setTimeout

        };
        // Fim da função onsubmit do formulário

        // ===== ROLAGEM SUAVE PARA OS LINKS DO MENU =====
        // Seleciona todos os links dentro da tag <nav>
        var linksMenu = document.querySelectorAll("nav a");

        // Para cada link do menu, adicionamos um evento de clique
        linksMenu.forEach(function(link) {
            // forEach = executa uma função para cada item da lista
            link.onclick = function(evento) {
                // Quando um link do menu é clicado

                // Pega o "href" do link (ex: "#inicio", "#sobre")
                var destino = this.getAttribute("href");
                // getAttribute("href") = pega o valor do atributo href

                // Encontra a seção de destino no documento
                var secao = document.querySelector(destino);
                // querySelector() = encontra um elemento pelo seletor CSS

                // Se a seção existe...
                if (secao) {
                    // Rola suavemente até a seção
                    secao.scrollIntoView({
                        // scrollIntoView() = rola até o elemento
                        behavior: "smooth",
                        // Rolagem suave
                        block: "start"
                        // Alinha o elemento ao topo da tela
                    });
                    // Fim do scrollIntoView
                }
                // Fim do if

            };
            // Fim da função onclick
        });
        // Fim do forEach

        // Mensagem no console do navegador (apenas para desenvolvimento)
        console.log("🌱 Site do Projeto Horta Sustentável carregado com sucesso!");
        // console.log() = imprime uma mensagem no console do navegador
        // Útil para verificar se o JavaScript está funcionando

    </script>
    <!-- Fim do bloco de JavaScript -->

</body>
<!-- Fim do corpo da página -->

